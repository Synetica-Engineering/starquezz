# Copy to supabase/functions/.env (gitignored) and fill in.
# The Scout uses a cheap fast model (Haiku-class); calls are rare — setup +
# occasional refresh — so cost is ≈ zero.
ANTHROPIC_API_KEY=sk-ant-...
# …or, alternatively, an OpenRouter key (Skematika-style) — the function
# accepts either and uses the same Claude Haiku model behind it:
# OPENROUTER_API_KEY=sk-or-...
