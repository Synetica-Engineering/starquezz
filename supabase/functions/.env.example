# Copy to supabase/functions/.env (gitignored) and fill in.
# The Scout uses a cheap fast model (DeepSeek V4 Flash); calls are rare — setup +
# occasional refresh — so cost is ≈ zero.
DEEPSEEK_API_KEY=sk-...
# …or, alternatively, an OpenRouter key for the same model:
# OPENROUTER_API_KEY=sk-or-...
# Anthropic is still supported as a fallback for older deployments:
# ANTHROPIC_API_KEY=sk-ant-...
